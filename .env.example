# Copy to .env and fill in your own values. NEVER commit the real .env.

# Base URL of your Bifrost (or any OpenAI-compatible) gateway.
BIFROST_BASE_URL=https://your-gateway.example.com/v1

# Your gateway key. Bifrost virtual keys typically start with sk-bf-
BIFROST_API_KEY=sk-bf-xxxxxxxxxxxxxxxx

# Default model, in provider/model form (see the skill's model table).
BIFROST_MODEL=openai/gpt-4o-mini
